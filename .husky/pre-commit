#!/usr/bin/env sh
# Git binary is x86_64; force arm64 child processes so native bindings
# (rollup, vitest, etc.) resolve to the correct platform variant.
if [ "$(uname -m)" = "arm64" ] || [ -x /usr/bin/arch ]; then
  exec arch -arm64 sh -c '
    npx lint-staged &&
    npm run typecheck &&
    npm run test
  '
else
  npx lint-staged
  npm run typecheck
  npm run test
fi
